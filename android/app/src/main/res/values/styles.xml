<resources>

    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <item name="android:statusBarColor">@color/union_primary</item>
        <item name="android:navigationBarColor">@color/union_primary</item>
    </style>

    <!-- Splash screen theme — shown during cold start before React Native renders -->
    <!-- Background: TEE 1104 Union primary red #C62828 -->
    <style name="SplashTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/union_primary</item>
        <item name="android:navigationBarColor">@color/union_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
